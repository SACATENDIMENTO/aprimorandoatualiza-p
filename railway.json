{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "echo 'Building PHP app'"
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "php -S 0.0.0.0:8080 -t .",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
